# =============================================================
# VARIÁVEIS DE AMBIENTE — LOGÍSTICA REVERSA FLÁVIA ORGANIZA
# =============================================================
# INSTRUÇÕES:
# 1. Copie este arquivo: cp .env.example .env.local
# 2. Preencha CADA variável com suas credenciais reais
# 3. NUNCA suba o .env.local para o Git (já está no .gitignore)
# =============================================================


# ─── SUPABASE ────────────────────────────────────────────────
# Como obter:
# 1. Acesse https://supabase.com/dashboard
# 2. Crie um novo projeto (gratuito)
# 3. Vá em: Project Settings → API
# 4. Copie "Project URL" e "anon public key"

NEXT_PUBLIC_SUPABASE_URL=https://XXXXXXXXXXXXXXXX.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX


# ─── TRAY COMMERCE ───────────────────────────────────────────
# Como obter:
# 1. Acesse https://app.tray.com.br
# 2. Vá em: Configurações → Integrações → API
# 3. Gere um token com permissão de leitura de pedidos
# 4. Copie o Store ID (número da sua loja)

TRAY_API_URL=https://api.dooki.com.br/v2
TRAY_API_KEY=SEU_TOKEN_TRAY_AQUI
TRAY_STORE_ID=SEU_STORE_ID_TRAY


# ─── BLING ERP ───────────────────────────────────────────────
# Como obter (API v3 — OAuth2):
# 1. Acesse https://app.bling.com.br
# 2. Vá em: Configurações → API → Aplicativos → Cadastrar
# 3. Complete o fluxo OAuth2 e obtenha o Access Token
# 4. Anote o ID da "Natureza de Operação" de devolução
#    (Cadastros → Naturezas de Operação → criar ou copiar)

BLING_API_KEY=SEU_ACCESS_TOKEN_BLING
BLING_NATUREZA_DEVOLUCAO_ID=123456


# ─── MELHOR ENVIO ────────────────────────────────────────────
# Como obter:
# 1. Acesse https://melhorenvio.com.br
# 2. Crie uma conta ou faça login
# 3. Vá em: Minha Conta → Tokens de Acesso → Criar token
# 4. Permissões necessárias: "Gerar etiquetas", "Comprar etiquetas"
# 5. Para testes, use o ambiente sandbox:
#    https://sandbox.melhorenvio.com.br (token separado)

MELHOR_ENVIO_TOKEN=SEU_TOKEN_MELHOR_ENVIO
MELHOR_ENVIO_CLIENT_ID=SEU_CLIENT_ID
MELHOR_ENVIO_ENV=sandbox
# Mude para "production" quando estiver pronto para produção

# ID do serviço de frete reversa (consultar via API ou painel)
# 1 = Correios PAC | 2 = Correios Sedex | 3 = Jadlog
MELHOR_ENVIO_SERVICO_ID=1


# ─── DADOS DA LOJA (para etiqueta de envio) ──────────────────
# Endereço de destino das devoluções

LOJA_EMAIL=contato@lojaflaviaorganiza.com.br
LOJA_CNPJ=00.000.000/0001-00
LOJA_TELEFONE=11999999999
LOJA_ENDERECO=Rua Exemplo
LOJA_NUMERO=123
LOJA_COMPLEMENTO=Sala 1
LOJA_BAIRRO=Bairro
LOJA_CIDADE=São Paulo
LOJA_UF=SP
LOJA_CEP=01310-000

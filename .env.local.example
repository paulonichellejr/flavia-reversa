# =====================================================
# VARIÁVEIS DE AMBIENTE — LOGÍSTICA REVERSA FLÁVIA ORGANIZA
# Copie este arquivo para .env.local e preencha os valores.
# No Vercel: Settings > Environment Variables
# =====================================================

# ─── SUPABASE ─────────────────────────────────────────────────
# Obtenha em: https://app.supabase.com > seu projeto > Settings > API
NEXT_PUBLIC_SUPABASE_URL=https://XXXX.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGci...
SUPABASE_SERVICE_ROLE_KEY=eyJhbGci...

# ─── BLING ERP v3 (OAuth) ─────────────────────────────────────
# Obtenha em: https://www.bling.com.br/b/configuracoes-api.php
# Após autenticar, o sistema salva o token no Supabase automaticamente.
BLING_CLIENT_ID=seu_client_id
BLING_CLIENT_SECRET=seu_client_secret
# URL de callback OAuth (configure no painel Bling):
BLING_REDIRECT_URI=https://sua-url.vercel.app/api/auth/bling/callback

# ─── MELHOR ENVIO ─────────────────────────────────────────────
# Obtenha em: https://melhorenvio.com.br > Integrações > Tokens de Acesso
# Permissão necessária: "Gerar etiquetas de devolução"
MELHOR_ENVIO_TOKEN=seu_token_melhor_envio
MELHOR_ENVIO_CLIENT_ID=seu_client_id_me
# Ambiente: "sandbox" para testes, "production" para produção
MELHOR_ENVIO_ENV=production
# ID do serviço de LOGÍSTICA REVERSA (verifique na sua conta ME):
# Correios PAC Reversa = geralmente 1; confirme em: ME > Meu Painel > Serviços
MELHOR_ENVIO_SERVICO_ID=1

# ─── MELHOR ENVIO — CONFIGURAÇÕES DE TESTE ────────────────────
# MELHOR_ENVIO_MODO_TESTE=true  → Retorna etiqueta simulada SEM chamar a API do ME
#                                  (nenhum saldo debitado, nenhum e-mail do ME)
# MELHOR_ENVIO_EMAIL_TESTE=     → Redireciona e-mails para este endereço (não chega ao cliente real)
#                                  Remova em produção!
# MELHOR_ENVIO_MODO_TESTE=true
# MELHOR_ENVIO_EMAIL_TESTE=seu@email.com.br
MELHOR_ENVIO_DOCUMENTO_TESTE=12345678909

# ─── DADOS DA LOJA (usados na etiqueta dos Correios) ──────────
# OBRIGATÓRIO: sem esses dados a etiqueta falha com "Transportadora não atende este trecho"
LOJA_EMAIL=contato@lojaflaviaorganiza.com.br
LOJA_ENDERECO=Rua Maximiliano Furbringer
LOJA_NUMERO=115
LOJA_COMPLEMENTO=
LOJA_BAIRRO=Jardim Maluche
LOJA_CIDADE=Brusque
LOJA_UF=SC
LOJA_CEP=88354670
# CPF do sócio/responsável (a API do ME exige CPF, não CNPJ, na logística reversa)
LOJA_CPF_RESPONSAVEL=00000000000

# ─── E-MAIL TRANSACIONAL (Gmail SMTP via nodemailer) ─────────
# Use a conta Gmail da loja: lojaflaviaorganiza@gmail.com
#
# Para gerar a Senha de App (não é a senha normal do Gmail):
# 1. Acesse: https://myaccount.google.com/security
# 2. Ative a "Verificação em duas etapas" (se ainda não ativou)
# 3. Pesquise por "Senhas de app" na mesma página
# 4. Crie uma senha para "Outro app" → nomeie "Flávia Reversa" → Gerar
# 5. Copie a senha de 16 caracteres e cole abaixo (com ou sem espaços)
#
GMAIL_USER=lojaflaviaorganiza@gmail.com
GMAIL_APP_PASSWORD=xxxx xxxx xxxx xxxx

# ─── SEGURANÇA ────────────────────────────────────────────────
# Segredo para proteger o endpoint de renovação automática do token Bling
# Configure também em: cron-job.org > Headers > Authorization: Bearer {valor}
CRON_SECRET=gere_uma_string_aleatoria_segura
